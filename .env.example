# sha256 hash of the API key clients must send in the X-API-Key header.
# Example below is the hash of "dev-local-key" — fine for local dev, change for anything real.
# Compute your own: python3 -c "import hashlib; print(hashlib.sha256(b'your-key').hexdigest())"
API_KEY_HASH=3700285e3c8496a57e45eb1ccd43f2424852788576961320fbb31f86f17edb61

RATE_LIMIT_PER_MINUTE=60
ENVIRONMENT=development
