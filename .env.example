# Copy to .env and fill in real values. Never commit .env.

DATABASE_URL=postgresql+psycopg://test:test@localhost:5433/bike_routes_test

# API keys are issued via `uv run python -m scripts.manage_keys issue --label "..."`
# once the DB is migrated — no key lives in this file anymore (see api_keys table).

RATE_LIMIT_PER_MINUTE=60
ENVIRONMENT=development

# Local technical demo only (Prometheus/Grafana/Tempo via
# `docker compose --profile observability up -d`) — never true in production.
ENABLE_OBSERVABILITY=false
